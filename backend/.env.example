DEPLOYMENT_MODE=standalone
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# 数据库
# 生产环境（MySQL）：
# DATABASE_URL=mysql+aiomysql://用户名:密码@127.0.0.1:3306/ai_trainer?charset=utf8mb4
# 本地开发（SQLite）：
DATABASE_URL=sqlite+aiosqlite:///./data/ai_trainer.db

# 文件存储
UPLOAD_DIR=./uploads

# LLM - 通义千问
LLM_PROVIDER=qwen
QWEN_API_KEY=sk-your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ASR - 豆包大模型语音识别
ASR_PROVIDER=doubao
DOUBAO_APP_ID=your_doubao_app_id
DOUBAO_ACCESS_KEY=your_doubao_access_key
DOUBAO_SECRET_KEY=your_doubao_secret_key

# TTS - MiniMax
TTS_PROVIDER=minimax
MINIMAX_API_KEY=your_minimax_api_key

# 跨域白名单（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 豆包图像生成（可选）
DOUBAO_IMAGE_API_KEY=your_doubao_image_api_key
